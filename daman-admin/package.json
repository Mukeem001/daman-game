{
  "name": "matka-admin-panel",
  "version": "1.0.0",
  "description": "Matka Admin Panel - Express.js API Server with React Frontend",
  "type": "module",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "artifacts/admin-panel",
    "artifacts/api-server",
    "lib/api-client-react",
    "lib/api-zod",
    "lib/db"
  ],
  "scripts": {
    "dev": "npx tsx --watch src/index.ts",
    "build": "tsc --build tsconfig.json",
    "start": "npx tsx ./src/index.ts",
    "typecheck": "tsc --build tsconfig.json --noEmit"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "date-fns": "^3.6.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.0",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "vite": "^8.0.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
